# Ghost Admin API (square.antiegg.kr)
# Ghost 관리자 → Settings → Integrations → Custom Integration
# 형식: {id}:{secret}
GHOST_API_URL=https://square.antiegg.kr
GHOST_ADMIN_API_KEY=

# WordPress REST API (antiegg.kr)
# WP 관리자 → 사용자 → 프로필 → 애플리케이션 비밀번호
WP_API_URL=https://antiegg.kr
WP_USERNAME=
WP_APP_PASSWORD=

# Google Cloud Translation API (슬러그 영어 번역용, 선택)
GOOGLE_TRANSLATE_API_KEY=

# ===== 브런치 자동 발행 (선택) =====
# 로컬 개발에서는 UI 세션 갱신 폼으로 쿠키를 저장하므로 비워둬도 됨.
# 파일 경로는 기본 프로젝트 루트의 .brunch-session.json (gitignore됨).
BRUNCH_SESSION_FILE=

# GitHub Actions 등 파일 쓰기가 어려운 환경에서는 아래 두 개를 Secret으로 주입.
# 브라우저 cURL 복사 후 cookie/x-csrf-token 헤더 값을 각각 넣기.
BRUNCH_COOKIE=
BRUNCH_CSRF_TOKEN=
