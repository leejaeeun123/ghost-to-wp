{
  "name": "ghost-to-wp",
  "version": "1.0.0",
  "description": "Ghost(square.antiegg.kr) -> WordPress(antiegg.kr) 아티클 자동 이전 도구",
  "type": "module",
  "scripts": {
    "sync": "tsx src/index.ts",
    "sync:dry": "tsx src/index.ts --dry-run",
    "sync:all": "tsx src/index.ts --all",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/server.ts",
    "auto-sync": "tsx src/scheduled-sync.ts",
    "naver:bootstrap": "tsx scripts/naver-poc/bootstrap-session.ts",
    "naver:probe": "tsx scripts/naver-poc/probe.ts",
    "naver:probe2": "tsx scripts/naver-poc/probe2.ts",
    "naver:probe3": "tsx scripts/naver-poc/probe3.ts",
    "naver:fill": "tsx scripts/naver-poc/fill-and-autosave.ts",
    "naver:fill2": "tsx scripts/naver-poc/fill-v2.ts",
    "naver:fill3": "tsx scripts/naver-poc/fill-v3.ts",
    "naver:fill4": "tsx scripts/naver-poc/fill-v4.ts",
    "naver:modal": "tsx scripts/naver-poc/publish-modal-probe.ts",
    "naver:dropdown": "tsx scripts/naver-poc/dropdown-probe.ts",
    "naver:dropdown2": "tsx scripts/naver-poc/dropdown-probe-v2.ts",
    "naver:publish-dry": "tsx scripts/naver-poc/publish-test.ts",
    "naver:publish-real": "tsx scripts/naver-poc/publish-test.ts --publish",
    "naver:cli": "tsx scripts/naver-poc/publish-cli.ts",
    "naver:align-diagnose": "tsx scripts/naver-poc/align-diagnose.ts",
    "naver:paste-debug": "tsx scripts/naver-poc/paste-debug.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/sharp": "^0.31.1",
    "playwright": "^1.59.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
