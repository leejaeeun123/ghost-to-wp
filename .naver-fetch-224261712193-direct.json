              },
              "@ctype": "paragraph"
            },
            {
              "id": "SE-f8ec698b-5c60-4470-b2d6-58a42ae56853",
              "nodes": [
                {
                  "id": "SE-29d53694-8dc9-44bc-8487-ee24bff872db",
                  "value": "",
                  "style": {
                    "fontColor": "#141414",
                    "fontFamily": "nanumbarungothic",
