              "nodes": [
                {
                  "id": "SE-cc3a3252-d87b-41de-a0cf-e442a3fdda92",
                  "value": "그때 그 사람이 떠나기 전, 어떻게 하는 것이 나의 최선이었을까. ",
                  "style": {
                    "fontColor": "#141414",
                    "fontFamily": "nanumbarungothic",
                    "fontSizeCode": "fs16",
                    "@ctype": "nodeStyle"
                  },
                  "@ctype": "textNode"
